    },
    "Email Confirmación": {
      "main": [[{ "node": "Responder OK", "type": "main", "index": 0 }]]
    },
    "Webhook Cancelar Reserva": {
      "main": [[{ "node": "Buscar Reserva por Token", "type": "main", "index": 0 }]]
    },
    "Buscar Reserva por Token": {
      "main": [[{ "node": "Verificar Plazo Cancelación", "type": "main", "index": 0 }]]
