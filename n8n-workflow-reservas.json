      ]
    },
    "Marcar como Cancelada": {
      "main": [[{ "node": "Email Cancelación Confirmada", "type": "main", "index": 0 }]]
    },
    "Email Cancelación Confirmada": {
      "main": [[{ "node": "Responder Cancelación OK", "type": "main", "index": 0 }]]
    }
  },

  "active": false,
  "settings": { "executionOrder": "v1" },
  "tags": ["utopia", "reservas", "restaurante"]
}
